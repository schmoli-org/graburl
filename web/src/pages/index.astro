<script>
  const btn = document.getElementById('theme-btn') as HTMLButtonElement;
  const menu = document.getElementById('theme-menu') as HTMLElement;
  const html = document.documentElement;

  const SVG: Record<string, string> = {
    light: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
    dark: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`,
    system: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  };

  function getState(): string {
    return localStorage.getItem('theme') || 'system';
  }

  function apply(state: string) {
    if (state === 'system') {
      html.removeAttribute('data-theme');
      localStorage.removeItem('theme');
    } else {
      html.setAttribute('data-theme', state);
      localStorage.setItem('theme', state);
    }
    btn.innerHTML = SVG[state];
    btn.setAttribute('aria-label', `Theme: ${state}`);
    document.querySelectorAll<HTMLElement>('.theme-option').forEach(opt => {
      opt.classList.toggle('active', opt.dataset.theme === state);
    });
  }

  function closeMenu() {
    menu.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  }

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    const opening = !menu.classList.contains('open');
    menu.classList.toggle('open', opening);
    btn.setAttribute('aria-expanded', String(opening));
  });

  document.querySelectorAll<HTMLElement>('.theme-option').forEach(opt => {
    opt.addEventListener('click', () => {
      apply(opt.dataset.theme!);
      closeMenu();
    });
  });

  document.addEventListener('click', closeMenu);

  apply(getState());
</script>
