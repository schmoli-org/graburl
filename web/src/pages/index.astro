---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GrabURL — Copy any URL instantly">
  <!-- ── Nav ── -->
  <header class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <svg width="28" height="28" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <linearGradient id="nb" x1="0" y1="0" x2="120" y2="120" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#4AB5FF"/>
              <stop offset="100%" stop-color="#0055C9"/>
            </linearGradient>
          </defs>
          <rect width="120" height="120" rx="26" fill="url(#nb)"/>
          <g transform="translate(20 20) scale(3.3333)" stroke="white" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </g>
        </svg>
        <span>GrabURL</span>
      </a>
      <div class="nav-actions">
      <a href="https://github.com/schmoli-org/graburl" class="nav-github" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub">
        <svg width="16" height="16" viewBox="0 0 98 96" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z" fill="currentColor"/>
        </svg>
      </a>
      <div class="theme-picker" id="theme-picker">
        <button class="theme-btn" id="theme-btn" aria-haspopup="true" aria-expanded="false" aria-label="Theme"></button>
        <div class="theme-menu" id="theme-menu" role="menu">
          <button class="theme-option" data-theme="system" role="menuitem">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            System
          </button>
          <button class="theme-option" data-theme="light" role="menuitem">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            Light
          </button>
          <button class="theme-option" data-theme="dark" role="menuitem">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            Dark
          </button>
        </div>
      </div>
      </div>
    </div>
  </header>

  <main>
    <!-- ── Hero ── -->
    <section class="hero">
      <svg class="hero-icon" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="hb" x1="0" y1="0" x2="120" y2="120" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#4AB5FF"/>
            <stop offset="100%" stop-color="#0055C9"/>
          </linearGradient>
          <linearGradient id="hs" x1="0" y1="0" x2="0" y2="120" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="white" stop-opacity="0.2"/>
            <stop offset="50%" stop-color="white" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <rect width="120" height="120" rx="26" fill="url(#hb)"/>
        <rect width="120" height="120" rx="26" fill="url(#hs)"/>
        <g transform="translate(20 20) scale(3.3333)" stroke="white" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </g>
      </svg>

      <h1>GrabURL</h1>
      <p class="tagline">Copy any URL instantly.</p>
      <p class="description">
        A browser extension for Safari and Chrome that puts the current page's URL on your clipboard with a single click. Nothing more, nothing less.
      </p>
      <div class="hero-actions">
        <a href="https://chromewebstore.google.com/detail/mhnhmpcmbgdohenoknpfionidnilgijc" target="_blank" rel="noopener noreferrer" class="btn btn-lg">
          Add to Chrome
        </a>
        <a href="https://testflight.apple.com/join/w6wuGu5k" target="_blank" rel="noopener noreferrer" class="btn btn-lg btn-outline">
          Safari beta — TestFlight
        </a>
      </div>
      <p class="availability">Chrome · Safari (macOS)</p>
    </section>

    <!-- ── Demo strip ── -->
    <div class="demo-strip">
      <div class="demo-inner">
        <div class="toolbar-mock" aria-label="Browser toolbar demo">
          <div class="toolbar-dots">
            <span></span><span></span><span></span>
          </div>
          <div class="address-bar">
            <span class="address-lock">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <span class="address-text">anthropic.com/research</span>
          </div>
          <div class="toolbar-ext">
            <svg width="16" height="16" viewBox="0 0 120 120" fill="none" aria-hidden="true">
              <rect width="120" height="120" rx="20" fill="#0077ED"/>
              <g transform="translate(20 20) scale(3.3333)" stroke="white" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </g>
            </svg>
          </div>
        </div>
        <div class="demo-arrow">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
        <div class="clipboard-mock">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
            <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
          </svg>
          <span>anthropic.com/research</span>
          <span class="copied-badge">Copied!</span>
        </div>
      </div>
    </div>

    <!-- ── Features ── -->
    <section class="features">
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon-wrap">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0077ED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <h3>One click</h3>
          <p>Click the toolbar icon. URL copied. That's the entire workflow — no popups, no menus, no confirmation dialogs.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrap">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0077ED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Private by design</h3>
          <p>Reads only the current tab's URL. No network requests, no tracking, no data ever leaves your device.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrap">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0077ED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2" ry="2"/>
              <path d="M6 8h.01"/><path d="M10 8h.01"/><path d="M14 8h.01"/><path d="M18 8h.01"/>
              <path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/>
              <path d="M7 16h10"/>
            </svg>
          </div>
          <h3>Keyboard shortcut</h3>
          <p>Grab the URL without touching the mouse. Cmd+Shift+C on Safari, Alt+Shift+C on Chrome.</p>
        </div>
      </div>
    </section>

    <!-- ── How to use ── -->
    <section class="how-to">
      <div class="how-to-inner">
        <h2 class="how-to-heading">How to use</h2>
        <div class="how-to-grid">
          <div class="how-to-card">
            <div class="feature-icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0077ED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m4 4 7.07 17 2.51-7.39L21 11.07z"/>
              </svg>
            </div>
            <h3>Click the toolbar icon</h3>
            <p>Pin GrabURL to your browser toolbar, then click the icon on any tab. The URL copies instantly and the popup closes on its own.</p>
          </div>
          <div class="how-to-card">
            <div class="feature-icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0077ED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2" ry="2"/>
                <path d="M6 8h.01"/><path d="M10 8h.01"/><path d="M14 8h.01"/><path d="M18 8h.01"/>
                <path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/>
                <path d="M7 16h10"/>
              </svg>
            </div>
            <h3>Keyboard shortcut</h3>
            <p>Copy the URL without touching the mouse. Shortcuts vary by browser:</p>
            <div class="shortcut-list">
              <div class="shortcut-row">
                <span class="shortcut-label">Safari · macOS</span>
                <span class="shortcut-keys"><kbd>⌘</kbd><kbd>⇧</kbd><kbd>C</kbd></span>
              </div>
              <div class="shortcut-row">
                <span class="shortcut-label">Chrome · macOS</span>
                <span class="shortcut-keys"><kbd>⌥</kbd><kbd>⇧</kbd><kbd>C</kbd></span>
              </div>
              <div class="shortcut-row">
                <span class="shortcut-label">Chrome · Windows</span>
                <span class="shortcut-keys"><kbd>Alt</kbd><kbd>Shift</kbd><kbd>C</kbd></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ── Footer ── -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-brand">
        <svg width="18" height="18" viewBox="0 0 120 120" fill="none" aria-hidden="true">
          <defs>
            <linearGradient id="fb" x1="0" y1="0" x2="120" y2="120" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#4AB5FF"/>
              <stop offset="100%" stop-color="#0055C9"/>
            </linearGradient>
          </defs>
          <rect width="120" height="120" rx="26" fill="url(#fb)"/>
          <g transform="translate(20 20) scale(3.3333)" stroke="white" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </g>
        </svg>
        GrabURL
      </a>
      <span class="footer-divider">·</span>
      <a href="/privacy">Privacy</a>
      <span class="footer-divider">·</span>
      <a href="https://github.com/schmoli-org/graburl/issues" target="_blank" rel="noopener noreferrer">Support</a>
      <span class="footer-divider">·</span>
      <a href="https://github.com/schmoli-org/graburl" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="footer-copy">© 2026</span>
    </div>
  </footer>
</Layout>

<style>
  /* ── Nav ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: var(--text);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nav-github {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-2);
    padding: 6px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .nav-github:hover {
    background: var(--bg-alt);
    color: var(--text);
  }

  /* ── Theme picker ── */
  .theme-picker {
    position: relative;
    flex-shrink: 0;
  }

  .theme-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-2);
    padding: 6px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, background 0.15s;
  }

  .theme-btn:hover {
    background: var(--bg-alt);
    color: var(--text);
  }

  .theme-menu {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 4px;
    min-width: 136px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.08);
    z-index: 200;
  }

  .theme-menu.open {
    display: block;
  }

  .theme-option {
    display: flex;
    align-items: center;
    gap: 9px;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-2);
    font-family: inherit;
    font-size: 14px;
    padding: 8px 12px;
    border-radius: 8px;
    text-align: left;
    transition: background 0.1s, color 0.1s;
  }

  .theme-option:hover {
    background: var(--bg-alt);
    color: var(--text);
  }

  .theme-option.active {
    color: var(--blue);
    font-weight: 500;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: inherit;
    font-size: 15px;
    font-weight: 500;
    padding: 9px 20px;
    border-radius: 980px;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    cursor: pointer;
    border: none;
    background: var(--blue);
    color: white;
  }

  .btn:hover {
    background: var(--blue-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(0, 85, 201, 0.38);
  }

  .btn:active {
    transform: translateY(0);
  }

  .btn-sm {
    font-size: 14px;
    padding: 7px 16px;
  }

  .btn-lg {
    font-size: 17px;
    padding: 14px 32px;
  }

  .btn-outline {
    background: transparent;
    color: var(--blue);
    box-shadow: inset 0 0 0 1.5px var(--blue);
  }

  .btn-outline:hover {
    background: var(--blue);
    color: white;
    box-shadow: 0 6px 20px rgba(0, 85, 201, 0.38);
  }

  /* ── Hero ── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 60px 24px 64px;
    max-width: 680px;
    margin: 0 auto;
  }

  .hero-icon {
    width: 140px;
    height: 140px;
    border-radius: 31px;
    box-shadow:
      0 24px 64px rgba(0, 85, 201, 0.32),
      0 4px 16px rgba(0, 0, 0, 0.1);
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(52px, 9vw, 80px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 16px;
    color: var(--text);
  }

  .tagline {
    font-size: clamp(22px, 3.5vw, 30px);
    font-weight: 500;
    color: var(--blue);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  .description {
    font-size: 18px;
    line-height: 1.65;
    color: var(--text-2);
    max-width: 520px;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .availability {
    font-size: 13px;
    color: var(--text-2);
    letter-spacing: 0.01em;
  }

  /* ── Demo strip ── */
  .demo-strip {
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 40px 24px;
  }

  .demo-inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .toolbar-mock {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg);
    border-radius: 12px;
    padding: 10px 14px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.06);
    min-width: 280px;
  }

  .toolbar-dots {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .toolbar-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #d2d2d7;
  }

  .toolbar-dots span:nth-child(1) { background: #fc5f57; }
  .toolbar-dots span:nth-child(2) { background: #fdbc2c; }
  .toolbar-dots span:nth-child(3) { background: #34c749; }

  .address-bar {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--bg-alt);
    border-radius: 7px;
    padding: 5px 10px;
    font-size: 13px;
    color: var(--text-2);
    min-width: 0;
  }

  .address-lock {
    flex-shrink: 0;
    color: var(--text-2);
    display: flex;
  }

  .address-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text);
  }

  .toolbar-ext {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    background: var(--bg-alt);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
  }

  .toolbar-ext:hover {
    background: #e8e8ed;
  }

  .demo-arrow {
    color: var(--text-2);
    flex-shrink: 0;
  }

  .clipboard-mock {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg);
    border-radius: 12px;
    padding: 12px 16px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.06);
    font-size: 13px;
    color: var(--text-2);
  }

  .copied-badge {
    background: #34c749;
    color: white;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 980px;
