default_platform(:mac)

# ASC's buildUploads endpoint intermittently 404s an app that App.find just
# returned when the two calls run back-to-back (fastlane#29908, regression in
# fastlane 2.232.0); a few seconds of delay before retrying reliably recovers.
require "spaceship"
module Spaceship::ConnectAPI::TestFlight::API
  alias_method :get_build_uploads_without_retry, :get_build_uploads
  def get_build_uploads(**kwargs)
    tries = 0
    begin
      get_build_uploads_without_retry(**kwargs)
    rescue Spaceship::UnexpectedResponse => e
      tries += 1
      raise unless tries <= 3 && e.message.include?("does not exist")
      FastlaneCore::UI.important("Transient ASC 'resource does not exist' error; retrying in 3s (#{tries}/3)")
      sleep(3)
      retry
    end
  end
end

platform :mac do
  desc "Sync App Store signing certificates via match"
  lane :certs do
    match(
      type: "appstore",
      platform: "macos",
      app_identifier: ["com.schmoli.graburl", "com.schmoli.graburl.Extension"],
      additional_cert_types: ["mac_installer_distribution"]
    )
  end

  desc "Build Release .pkg, upload to TestFlight, and distribute to the 'auto' internal group"
  lane :release do
    # Fetch the build number BEFORE match: match's portal login poisons the
    # shared ASC web session for the buildUploads endpoint for several minutes
    # (verified 2026-06-11: identical call succeeds before `certs`, fails
    # immediately after).
    latest_build = begin
      latest_testflight_build_number(
        app_identifier: "com.schmoli.graburl",
        platform: "osx"
      )
    rescue Spaceship::UnexpectedResponse => e
      raise unless e.message.include?("does not exist")
      # buildUploads outage can last minutes; the legacy builds endpoint
      # (what this action used before fastlane 2.232.0) is unaffected.
      UI.important("buildUploads endpoint is misbehaving (fastlane#29908); falling back to the legacy builds endpoint")
      app = Spaceship::ConnectAPI::App.find("com.schmoli.graburl")
      build = Spaceship::ConnectAPI.get_builds(
        filter: { app: app.id, "preReleaseVersion.platform" => "MAC_OS" },
        sort: "-uploadedDate",
        includes: "preReleaseVersion",
        limit: 1
      ).first
      UI.user_error!("No TestFlight builds found via the builds endpoint either") unless build
      UI.important("Latest TestFlight build via fallback: #{build.version}")
      build.version.to_i
    end
    certs
    increment_build_number(
      build_number: latest_build + 1,
      xcodeproj: "GrabURL/GrabURL.xcodeproj"
    )
    # Several "Apple Distribution" identities share a name in the local keychain;
    # pin the export to the exact certificate embedded in the match profile.
    profile_path = ENV.fetch("sigh_com.schmoli.graburl_appstore_macos_profile-path")
    signing_cert_sha = sh(
      "security cms -D -i '#{profile_path}' | " \
      "plutil -extract DeveloperCertificates.0 raw - | base64 -d | " \
      "openssl x509 -inform der -noout -fingerprint -sha1 | " \
      "sed -E 's/.*=//; s/://g'",
      log: false
    ).strip
    build_mac_app(
      project: "GrabURL/GrabURL.xcodeproj",
      scheme: "GrabURL",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/release",
      xcargs: "DEVELOPMENT_TEAM=#{ENV['DEVELOPMENT_TEAM']}",
      export_options: {
        signingCertificate: signing_cert_sha,
        installerSigningCertificate: "3rd Party Mac Developer Installer"
      }
    )
    pkg_path = lane_context[SharedValues::PKG_OUTPUT_PATH]
    UI.user_error!("No .pkg was produced — Mac App Store upload requires a signed pkg") unless pkg_path && File.exist?(pkg_path)
    upload_to_testflight(
      pkg: pkg_path,
      app_platform: "osx",
      groups: ["auto"],
      # 'auto' is an internal group; without this pilot would submit the build
      # for Beta App Review (external-testing flow) and fail on missing Test Info.
      submit_beta_review: false,
      skip_waiting_for_build_processing: false
    )
  end

  desc "Promote the latest TestFlight build to the external 'beta' group"
  lane :promote do
    upload_to_testflight(
      distribute_only: true, # no build/upload — distributes the latest processed build
      app_platform: "osx",
      groups: ["beta"],
      distribute_external: true,
      # External groups require Beta App Review; first build of each version
      # waits in review (<24h typically), later builds are near-instant.
      submit_beta_review: true,
      changelog: ENV.fetch("CHANGELOG", "Bug fixes and improvements")
    )
  end

  desc "Submit the current version to App Store review"
  lane :submit do
    deliver(
      platform: "osx",
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      skip_screenshots: Dir[File.join(__dir__, "screenshots/**/*.png")].empty?,
      primary_category: "UTILITIES",
      secondary_category: "PRODUCTIVITY",
      # Age rating is NOT set here: fastlane 2.236.1 cannot satisfy Apple's
      # new age-rating questionnaire (the API rejects the PATCH for missing
      # required fields like ageAssurance/lootBox/userGeneratedContent).
      # Set the age rating once in the App Store Connect web UI instead.
      # Assumes a build was already uploaded via `fastlane mac release`;
      # this lane only pushes metadata/screenshots and triggers review.
      skip_binary_upload: true,
      submit_for_review: true,
      automatic_release: false,
      force: true
    )
  end
end
