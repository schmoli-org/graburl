# Copy this file to `.env` and fill in the values below.
DEVELOPMENT_TEAM=YOUR_TEAM_ID

# fastlane / App Store Connect
APPLE_ID=you@example.com
MATCH_GIT_URL=git@github.com:YOUR_ORG/certs.git
MATCH_PASSWORD=<passphrase to encrypt the certs repo>
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=<app-specific password from appleid.apple.com>
ITC_TEAM_NAME=<your App Store Connect team name, e.g. "Nicholas Leonovich">

# Chrome Web Store (one-time OAuth setup: docs/chrome-store-submission.md)
EXTENSION_ID=mhnhmpcmbgdohenoknpfionidnilgijc
CLIENT_ID=<google oauth desktop client id>
CLIENT_SECRET=<google oauth desktop client secret>
REFRESH_TOKEN=<refresh token from the one-time consent flow>
